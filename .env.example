# Copy this file to .env.local for local development and set the same
# values in your Vercel project's Environment Variables for production.
# Get these from https://console.twilio.com after creating a Twilio account
# and buying a phone number.

TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=+1XXXXXXXXXX
